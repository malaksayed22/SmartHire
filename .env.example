# Copy to .env.local (not committed) — Vercel: Project → Settings → Environment Variables

# Backend (optional override)
# VITE_API_BASE_URL=https://your-api.example.com

# n8n — use one URL for everything, or split by flow:
# VITE_N8N_WEBHOOK_URL=https://your-n8n.app/webhook/xxxxx
# VITE_N8N_WEBHOOK_APPLICATION_URL=https://your-n8n.app/webhook/application
# VITE_N8N_WEBHOOK_STATUS_URL=https://your-n8n.app/webhook/status
